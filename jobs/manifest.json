{
    "manifest_version": 3,
    "name": "Decision making support system",
    "version": "1.0.0",
    "description": "Capture job postings for AI-powered analysis",
    "permissions": [
        "activeTab",
        "scripting",
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*",
        "http://job.117.72.155.176.nip.io:8888/*"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self';"
    },
    "action": {
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "background.js"
    }
}